# Generic nested overrides use MOSHIMO__SECTION__FIELD.
# Values are parsed as YAML scalars.
# Use true only while developing or diagnosing the app.
MOSHIMO__APP__DEBUG_MODE=false
MOSHIMO__APP__PUBLIC_BASE_URL=https://your-jupyterhub.example.jp
MOSHIMO__SERVER__DEFAULT_PORT=8789
MOSHIMO__LOGGING__LEVEL=INFO

# Shell/setup path overrides (export before running scripts):
# MOSHIMO_ENV_ROOT=/path/to/moshimo-box-envs
# MOSHIMO_MODEL_ROOT=/path/to/models

# Optional application path overrides:
# MOSHIMO__STORAGE__MODEL_ROOT=/another/local/path/models
# MOSHIMO__STORAGE__SESSION_ROOT=/another/local/path/sessions
